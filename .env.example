# ============================================
# Agentic QA — Environment Variables Template
# ============================================
# Copy this file to .env and fill in your actual values.
# NEVER commit your real .env file to version control.

# ── Required ─────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_API_BASE=https://api.openai.com/v1
MODEL_NAME=gpt-4o-mini

# ── Optional: Google Gemini ───────────────────
# GEMINI_API_KEY=your-gemini-api-key-here

# ── Optional: RAGAS ───────────────────────────
# RAGAS_API_KEY=your-ragas-api-key-here

# ── Optional: LangSmith Tracing ──────────────
# Get your key at https://smith.langchain.com
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=lsv2_your-langsmith-api-key-here
LANGCHAIN_PROJECT=agentic-qa
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# ── Pipeline Configuration ────────────────────
MAX_ITERATIONS=3
TESTS_PER_ITERATION=5
